# Copy this to .env and fill in all CHANGE_ME values before first run.
# Generate secrets with: openssl rand -hex 32

POSTGRES_USER=infisical
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=infisical

REDIS_PASSWORD=CHANGE_ME

ENCRYPTION_KEY=CHANGE_ME
AUTH_SECRET=CHANGE_ME

DB_CONNECTION_URI=postgresql://infisical:CHANGE_ME@postgres:5432/infisical
REDIS_URL=redis://:CHANGE_ME@redis:6379

SITE_URL=http://localhost:8090
NODE_ENV=production

# ── SMTP (optional — for Infisical email invites / password reset) ────────────
# Gmail: create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME@gmail.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_ADDRESS=CHANGE_ME@gmail.com
SMTP_FROM_NAME=IronNest Infisical
