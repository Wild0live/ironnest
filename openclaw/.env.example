# Copy to .env and fill in all CHANGE_ME values.

OPENCLAW_GATEWAY_TOKEN=CHANGE_ME
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# ── Infisical Agent (Universal Auth) ─────────────────────────────────────────
# The agent sidecar uses these to authenticate to Infisical, then renders
# agent-config/secrets.tmpl → secrets-runtime/.env before OpenClaw starts.
# Create a Machine Identity in Infisical UI → Access Control → Machine Identities,
# assign it read access to the openclaw project, and paste the credentials here.
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=CHANGE_ME
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=CHANGE_ME
INFISICAL_CLIENT_ID=CHANGE_ME
INFISICAL_CLIENT_SECRET=CHANGE_ME
INFISICAL_SITE_URL=http://infisical:8090

# ── AI provider keys ──────────────────────────────────────────────────────────
# Do NOT put API keys here. They are managed in Infisical and injected at
# runtime via secrets-runtime/.env. Add them as secrets in the Infisical UI:
#   Project: openclaw  |  Environment: dev  |  Path: /
#   Keys: ANTHROPIC_API_KEY, OPENAI_API_KEY, OPENAI_API_KEYS

TZ=UTC
