FROM ghcr.io/openclaw/openclaw:2026.4.23-amd64
# Install the OpenAI Codex CLI — required by OpenClaw's codex provider harness.
# OpenClaw spawns `codex` as a subprocess; without it every codex/* model request
# fails with "spawn codex ENOENT".
USER root
RUN npm install -g @openai/codex --no-audit --no-fund \
 && npm install -g @zed-industries/codex-acp --no-audit --no-fund \
 && codex --version

# Ensure the node user's XDG config dir exists and is writable (codex-acp reads config there)
RUN mkdir -p /home/node/.config && chown node:node /home/node/.config

# ── Browsers — Debian/Ubuntu path (apt) with Alpine fallback (apk, Chromium only) ──
RUN if command -v apt-get >/dev/null 2>&1; then \
      install -m 0755 -d /etc/apt/keyrings && \
      apt-get update && \
      apt-get install -y --no-install-recommends chromium chromium-sandbox gnupg && \
      curl -fsSL https://dl.google.com/linux/linux_signing_key.pub \
        | gpg --dearmor -o /etc/apt/keyrings/google-chrome.gpg && \
      printf 'deb [arch=amd64 signed-by=/etc/apt/keyrings/google-chrome.gpg] https://dl.google.com/linux/chrome/deb/ stable main\n' \
        > /etc/apt/sources.list.d/google-chrome.list && \
      curl -fsSL https://packages.microsoft.com/keys/microsoft.asc \
        | gpg --dearmor -o /etc/apt/keyrings/microsoft.gpg && \
      printf 'deb [arch=amd64 signed-by=/etc/apt/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/edge stable main\n' \
        > /etc/apt/sources.list.d/microsoft-edge.list && \
      apt-get update && \
      apt-get install -y --no-install-recommends google-chrome-stable microsoft-edge-stable && \
      rm -rf /var/lib/apt/lists/*; \
    elif command -v apk >/dev/null 2>&1; then \
      apk add --no-cache chromium chromium-chromedriver; \
    fi

# ── Browser extensions + profile dir ownership ────────────────────────────────
COPY --chown=node:node extensions/ /opt/browser-extensions/
RUN mkdir -p /home/node/.openclaw/browser-profiles && \
    chown -R node:node /home/node/.openclaw

ENV CHROMIUM_BIN=/usr/bin/chromium
ENV CHROME_BIN=/usr/bin/google-chrome-stable
ENV EDGE_BIN=/usr/bin/microsoft-edge-stable
ENV BROWSER_EXTENSIONS_DIR=/opt/browser-extensions
ENV BROWSER_PROFILES_DIR=/home/node/.openclaw/browser-profiles

# ttyd — static binary for browser-based terminal (used by openclaw-ttyd service)
RUN curl -fsSL https://github.com/tsl0922/ttyd/releases/download/1.7.7/ttyd.x86_64 \
      -o /usr/local/bin/ttyd \
 && chmod +x /usr/local/bin/ttyd \
 && ttyd --version
USER node
