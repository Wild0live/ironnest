# Copy to .env and fill in values. NEVER commit .env to git.
#
# This file holds ONLY the Infisical machine-identity creds the hermes
# containers need to authenticate at startup. All application secrets
# (OPENROUTER_API_KEY, Telegram tokens, ttyd creds, etc.) live in
# Infisical and are injected into the process env at startup by
# /usr/local/bin/with-infisical — they never appear in any file.
#
# Setup steps:
#   1. Create project "hermes" in Infisical (http://127.0.0.1:18090).
#   2. In env "dev", path "/", add the application secrets:
#        OPENROUTER_API_KEY=<key from openrouter.ai>   ← primary LLM provider
#        HERMES_TTYD_USERNAME=<choose a username>
#        HERMES_TTYD_PASSWORD=<choose a strong password>
#        TELEGRAM_BOT_TOKEN=<token from @BotFather>     ← optional messaging
#        TELEGRAM_ALLOWED_USERS=<numeric Telegram user id>
#        TELEGRAM_HOME_CHANNEL=<numeric chat/user id>   ← optional default target
#        TELEGRAM_HOME_CHANNEL_NAME=<friendly name>     ← optional label
#   3. Organization → Machine Identities → New → Name: hermes-gateway
#      Auth: Universal Auth, assign Viewer role to project hermes.
#   4. Copy clientId + clientSecret below.
#   5. Confirm INFISICAL_PROJECT_ID in docker-compose.yml matches the
#      project UUID from the Infisical URL (currently 2777cf9a-...).

INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=
