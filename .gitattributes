# Force LF for all shell scripts and config files regardless of OS
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.conf      text eol=lf
*.tmpl      text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.example   text eol=lf
*.gitignore text eol=lf
Dockerfile* text eol=lf

# Windows scripts use CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
