FROM elastic/filebeat:7.17.21
COPY filebeat/filebeat.yml /usr/share/filebeat/filebeat.yml
COPY filebeat/root-ca.pem  /certs/root-ca.pem
USER root
RUN chown root:filebeat /usr/share/filebeat/filebeat.yml && chmod 0640 /usr/share/filebeat/filebeat.yml
RUN apt-get update -qq && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
USER filebeat
