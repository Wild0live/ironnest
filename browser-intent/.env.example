# Copy to .env and fill in all CHANGE_ME values.

# ── Infisical Agent (Universal Auth) ─────────────────────────────────────────
# Create or reuse an IronNest Machine Identity in Infisical UI, assign it read
# access to the IronNest project paths below, and paste the credentials here.
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=CHANGE_ME
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=CHANGE_ME

# Replace this in agent-config/secrets.tmpl too. This should be the IronNest
# Infisical project UUID if Browser Intent lives inside the existing project.
IRONNEST_INFISICAL_PROJECT_ID=CHANGE_ME

# ── MCP HTTP front door auth ────────────────────────────────────────────────
# Required. Gates POST /mcp and GET /sites on 127.0.0.1:18901 so a local
# process or a malicious host-browser page cannot trigger real logins. stdio
# transport is unaffected (already process-local).
# Generate with:  openssl rand -hex 32
BROWSER_INTENT_MCP_TOKEN=CHANGE_ME

TZ=UTC
