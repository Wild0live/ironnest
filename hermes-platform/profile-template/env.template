# env.template — per-profile container environment
#
# Rendered by scripts/create-profile.sh into a docker-compose include
# fragment. Substitutions:
#   <PROFILE-NAME>      → mark | steve | analyst | ...
#   <CONTAINER-NAME>    → hermes-pf-<PROFILE-NAME>
#   <NAMESPACE>         → viking://profiles/<PROFILE-NAME>/
#   <APPROVED-SHARED>   → viking://shared/approved/<PROFILE-NAME>/

# The bearer token is NOT in this file. It comes from Infisical at
# /hermes-platform/<PROFILE-NAME> → MEMORY_GATEWAY_TOKEN, injected by
# with-infisical at container start.

HERMES_PROFILE=<PROFILE-NAME>

# Memory gateway endpoint (service DNS on hermes-platform-app-net)
MEMORY_GATEWAY_URL=http://memory-gateway:8080

# Telemetry tag for fluent-bit / Wazuh enrichment
IRONNEST_PROFILE_NAME=<PROFILE-NAME>
IRONNEST_PROFILE_NAMESPACE=<NAMESPACE>
IRONNEST_APPROVED_SHARED_NAMESPACE=<APPROVED-SHARED>
