# hermes-platform — Infisical machine-identity credentials
#
# Copy to ./.env and fill in the values from Infisical Admin → Project
# "hermes-platform" → Machine Identities. The .env file is gitignored.
#
# NEVER put application secrets here. All application secrets (bearer
# tokens, API keys, etc.) are stored in Infisical and fetched at process
# start by /usr/local/bin/with-infisical (in-process; never touches disk).
#
# These credentials are how the Infisical CLI authenticates to fetch the
# real application secrets. They are a Universal Auth machine identity
# scoped to project "hermes-platform" only — they cannot read other projects.

# Required — Universal Auth client credentials
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=

# Required — Infisical project ID for the hermes-platform project.
# Find at: Infisical UI → Project Settings → Project ID
INFISICAL_PROJECT_ID=

# Optional — overrides for non-default Infisical deployments
# INFISICAL_DOMAIN=http://infisical:8090
# INFISICAL_ENV=dev
