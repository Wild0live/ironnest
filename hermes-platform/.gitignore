# IronNest / hermes-platform — Git ignore rules
#
# Secrets and runtime state never enter the repo.

# Infisical machine-identity creds (per-host)
.env
.env.local
*.env.local

# Sidecar-rendered runtime secrets
secrets-runtime/
secrets-runtime/.env
secrets-runtime/*

# SOUL.md backups (timestamped, generated by scripts/patch-souls.sh)
*.bak.*
*.bak

# Gateway audit log (JSONL, generated at runtime)
gateway/audit.log
gateway/audit.log.*
gateway/app/__pycache__/
gateway/app/**/__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Per-profile data volumes are Docker-managed; nothing on host
# (but if anyone ever bind-mounts for debugging, ignore those paths)
data/
profiles-data/

# OpenViking workspace dumps if rendered locally for debugging
openviking/workspace/

# Shared artifact-exchange tree — agents dump generated binaries/files here at
# runtime. Keep the structure (README + .gitkeep) but ignore the artifacts.
shared/*/*
!shared/*/.gitkeep
!shared/README.md

# OS / editor noise
Thumbs.db
.DS_Store
*.swp
*.swo
.idea/
.vscode/
