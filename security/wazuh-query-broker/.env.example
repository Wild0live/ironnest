# Wazuh Query Broker secrets. Copy to .env and fill in. .env is gitignored.
#
# Prefer the dedicated read-only indexer user (see setup-readonly-user.md) over
# reusing `admin`. The broker only ever issues searches, but defence in depth
# means the credential it holds should itself be read-only.

WAZUH_BROKER_INDEXER_USER=broker_ro
WAZUH_BROKER_INDEXER_PASSWORD=CHANGE_ME

# Manager API user used for /agents and /rule lookups. The stack's wazuh-wui
# works; a read-only API role is better if you create one.
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=CHANGE_ME

# Bearer tokens allowed to call the broker — one per agent, comma-separated.
# Generate with: openssl rand -hex 32
WAZUH_QUERY_BROKER_TOKENS=octo_CHANGE_ME,littlejohn_CHANGE_ME
