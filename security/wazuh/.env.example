# Wazuh credentials. Copy to .env and fill in all CHANGE_ME values.
# Generate strong values with:  openssl rand -base64 24
#
# Do NOT keep the upstream Wazuh defaults (SecretPassword / MyS3cr37P450r.*- /
# kibanaserver) — they are publicly known and trivial to look up.
#
# If you set WAZUH_INDEXER_PASSWORD, you also need to regenerate the bcrypt
# hashes in config/wazuh_indexer/internal_users.yml and run
# /usr/share/wazuh-indexer/plugins/opensearch-security/tools/securityadmin.sh
# inside the indexer container so OpenSearch Security picks up the new hash.

WAZUH_INDEXER_PASSWORD=CHANGE_ME
WAZUH_API_PASSWORD=CHANGE_ME
WAZUH_DASHBOARD_PASSWORD=CHANGE_ME

# Infisical Universal Auth — used by wazuh-infisical-agent to render the
# Wazuh OIDC client_secret (raw form) into secrets-runtime/.env, which is
# then loaded into the dashboard's OpenSearch keystore at startup.
# Same project UUID as openclaw + hermes (63d75eb0-ef3a-4ce3-908d-46360b922fa8).
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=
