# Wazuh credentials. Copy to .env and customize.
# Leaving defaults is OK for a localhost-only personal deployment — the
# dashboard is not exposed beyond 127.0.0.1 — but changing them is recommended.
#
# If you change WAZUH_INDEXER_PASSWORD, you also need to regenerate the bcrypt
# hashes in config/wazuh_indexer/internal_users.yml and run
# /usr/share/wazuh-indexer/plugins/opensearch-security/tools/securityadmin.sh
# inside the indexer container. For now the Wazuh defaults are used.

WAZUH_INDEXER_PASSWORD=SecretPassword
WAZUH_API_PASSWORD=MyS3cr37P450r.*-
WAZUH_DASHBOARD_PASSWORD=kibanaserver
