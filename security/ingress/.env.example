# Ingress stack environment.
# Copy to .env and fill in the values. .env is gitignored — never commit it.

# Must match WAZUH_INDEXER_PASSWORD in security/wazuh/.env.
WAZUH_INDEXER_PASSWORD=

# Infisical Universal Auth — used by ingress-infisical-agent to render
# Authelia's OIDC HMAC secret, JWKS signing key, and Wazuh client_secret hash.
# Generate via Infisical UI → Project → Access Control → Identities →
# <ingress-identity> → Universal Auth → Add Client Secret.
# Same project/UUID as openclaw + hermes (63d75eb0-ef3a-4ce3-908d-46360b922fa8).
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=
